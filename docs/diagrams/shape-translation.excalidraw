      "id": "oai_content_text",
      "x": 98, "y": 190,
      "width": 410, "height": 195,
      "text": "{\n  \"role\": \"user\",\n  \"content\": [\n    {\"type\": \"text\",\n     \"text\": \"what is this?\"},\n    {\"type\": \"image_url\",\n     \"image_url\": {\n       \"url\": \"data:image/png;\n              base64,iVBOR...\"}}\n  ]\n}",
